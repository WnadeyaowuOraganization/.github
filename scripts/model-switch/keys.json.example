{
  "_doc": "智谱Coding Plan多Key配置 — Token Pool Proxy使用",
  "_usage": "复制此文件为 keys.json，填入实际API Key",

  "keys": [
    {
      "name": "zhipu_max_1",
      "api_key": "YOUR_API_KEY_HERE",
      "enabled": true
    },
    {
      "name": "zhipu_max_2",
      "api_key": "YOUR_SECOND_API_KEY_HERE",
      "enabled": false
    },
    {
      "name": "zhipu_max_3",
      "api_key": "YOUR_THIRD_API_KEY_HERE",
      "enabled": false
    }
  ],

  "upstream": {
    "base_url": "https://open.bigmodel.cn/api/anthropic",
    "default_models": {
      "haiku": "glm-4.5-air",
      "sonnet": "glm-5-turbo",
      "opus": "glm-5.1"
    }
  },

  "fallback": {
    "enabled": true,
    "vllm_url": "http://localhost:8000/v1/chat/completions",
    "vllm_model": "/model",
    "_note": "本地Qwen3.5-122B-A10B via vLLM, 所有智谱Key耗尽时自动降级"
  },

  "cooldown": {
    "rate_limit_hours": 5,
    "weekly_limit_hours": 168,
    "_note": "5小时限额冷却5h, 周限额冷却到下周期(最大168h). 连续触发自动升级为周冷却"
  }
}
