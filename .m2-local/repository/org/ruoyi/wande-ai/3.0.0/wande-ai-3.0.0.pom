    </dependency>
    <dependency>
      <groupId>org.ruoyi</groupId>
      <artifactId>ruoyi-system</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>org.eclipse.jgit</groupId>
      <artifactId>org.eclipse.jgit</artifactId>
