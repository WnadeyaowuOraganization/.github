// Issue 生命周期完整流水线
// 触发：GitHub Webhook pull_request 事件（opened/synchronize/reopened）
// 覆盖：pr-test + build-deploy-dev + cc-lock-manager + issue-sync

pipeline {
    agent any

    options {
        timeout(time: 2, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '30'))
        disableConcurrentBuilds()
    }

    triggers {
        GenericTrigger(
            genericVariables: [
                [key: 'PR_NUMBER',  value: '$.pull_request.number'],
                [key: 'BRANCH',     value: '$.pull_request.head.ref'],
                [key: 'PR_ACTION',  value: '$.action'],
                [key: 'PR_MERGED',  value: '$.pull_request.merged']
            ],
            causeString: 'PR #$PR_NUMBER ($PR_ACTION)',
            token: 'wande-play-pr',
            printContributedVariables: false,
            printPostContent: false,
            regexpFilterText: '$PR_ACTION',
            regexpFilterExpression: 'opened|synchronize|reopened'
        )
    }

    parameters {
        string(name: 'PR_NUMBER', defaultValue: '', description: 'PR Number')
        string(name: 'BRANCH',    defaultValue: '', description: 'Branch name')
    }

    environment {
        REPO         = 'WnadeyaowuOraganization/wande-play'
        CI_WORK_DIR  = '/home/ubuntu/projects/wande-play-ci'
        CI_BACKEND_PORT = '6041'
        CI_FRONTEND_PORT = '8084'
        CI_DB_NAME   = 'wande-ai-ci'
        SCRIPTS_DIR  = '/data/home/ubuntu/projects/.github/scripts'
        JENKINS_DIR  = '/data/home/ubuntu/projects/.github/jenkins'
        WANDE_DIR    = '/home/ubuntu/projects/wande-play'
    }

    stages {

        // ── 阶段1：拉取 PR 代码 ──────────────────────────────────────────
        stage('Checkout') {
            steps {
                withCredentials([string(credentialsId: 'github-bot-token', variable: 'BOT_TOKEN')]) {
                    script {
                        def branch = params.BRANCH ?: env.BRANCH ?: 'dev'
                        def prNum = params.PR_NUMBER ?: env.PR_NUMBER ?: ''
                        sh """
                            lsof +D ${CI_WORK_DIR} 2>/dev/null | awk 'NR>1{print \$2}' | sort -u | xargs -r kill -9 2>/dev/null || true
                            rm -rf ${CI_WORK_DIR}
                            mkdir -p ${CI_WORK_DIR}
                            cd ${CI_WORK_DIR}
                            # 直接克隆指定分支，避免 fetch 静默失败导致回退到错误代码
                            git clone --branch ${branch} --depth=50 https://wandeyaowu:${BOT_TOKEN}@github.com/${REPO} .
                            git fetch origin dev --depth=50
                            if git merge origin/dev --no-edit; then
                                echo "dev merged OK"
                            else
                                echo "WARN: dev merge failed — forcing full build+test (cannot reliably detect changes)"
                                echo "FORCE_FULL_BUILD=true" > ${CI_WORK_DIR}/.build_env
                            fi
                        """
                    }
                }
            }
        }

        // ── 阶段2：冲突检测 ──────────────────────────────────────────────
        stage('冲突检测') {
            when { expression { return (params.PR_NUMBER ?: env.PR_NUMBER)?.trim() } }
            steps {
                withCredentials([string(credentialsId: 'github-weiping-token', variable: 'WEIPING_TOKEN')]) {
                    script {
                        def pr = params.PR_NUMBER ?: env.PR_NUMBER
                        sh """
                            export GH_TOKEN="${WEIPING_TOKEN}"
                            bash ${JENKINS_DIR}/check-conflict.sh "${pr}" "${REPO}" "${JENKINS_DIR}" "${CI_WORK_DIR}"
                        """
                    }
                }
            }
        }

        // ── 阶段3：质量门控（快速失败）──────────────────────────────────
        stage('质量门控') {
            when { expression { return (params.PR_NUMBER ?: env.PR_NUMBER)?.trim() } }
            steps {
                script {
                    def pr = params.PR_NUMBER ?: env.PR_NUMBER
                    def branch = params.BRANCH ?: env.BRANCH ?: 'dev'
                    sh "bash ${JENKINS_DIR}/quality-gate.sh ${pr} ${branch}"
                }
            }
        }

        // ── 阶段4：检测变更模块（必须在前置，env vars 供后续 when 使用）────────
        stage('检测变更') {
            steps {
                script {
                    def forceFull = sh(
                        script: "cat ${CI_WORK_DIR}/.build_env 2>/dev/null || echo ''",
                        returnStdout: true
                    ).trim()
                    if (forceFull.indexOf('FORCE_FULL_BUILD=true') >= 0) {
                        // 合并失败时强制全量构建（避免 git diff 空导致跳过测试/部署）
                        env.HAS_BACKEND = 'true'
                        env.HAS_FRONTEND = 'true'
                        env.HAS_UNIT_TEST = 'true'
                        echo "⚠️ dev merge failed — forcing full backend+frontend build+test"
                    } else {
                        def changed = sh(
                            script: "cd ${CI_WORK_DIR} && git diff --name-only origin/dev HEAD 2>/dev/null | sort -u",
                            returnStdout: true
                        ).trim()
                        env.CHANGED_FILES = changed
                        env.HAS_BACKEND = (changed.indexOf('backend/') >= 0) ? 'true' : 'false'
                        env.HAS_FRONTEND = (changed.indexOf('frontend/') >= 0) ? 'true' : 'false'
                        env.HAS_UNIT_TEST = (changed.indexOf('backend/') >= 0) ? 'true' : 'false'
                        echo "变更检测 → backend=${env.HAS_BACKEND} frontend=${env.HAS_FRONTEND}"
                        echo "变更文件: ${changed.take(500)}"
                    }
                }
            }
        }

        // ── 阶段5：单元测试（仅后端变更时运行）────────────────────────────
        stage('单元测试') {
            when { expression { return env.HAS_UNIT_TEST == 'true' } }
            steps {
                sh """
                    cd ${CI_WORK_DIR}/backend
                    mvn test -pl ruoyi-modules/wande-ai -am -Pprod
                """
            }
        }

        // ── 阶段6：E2E 测试（暂禁用，待模块级过滤方案设计）──────────────────────
        // stage('E2E 测试') {
        //     when { expression { return (params.PR_NUMBER ?: env.PR_NUMBER)?.trim() } }
        //     steps {
        //         sh """
        //             # 启动 CI 环境（前后端），复用 unit test 已构建 jar
        //             bash ${JENKINS_DIR}/start-all.sh || { echo "❌ start-all.sh 失败"; exit 1; }
        //
        //             # 运行 Playwright E2E（只跑与 PR 变更相关的测试，smoke 兜底）
        //             PR_NUM="${params.PR_NUMBER ?: env.PR_NUMBER ?: ''}"
        //             cd ${CI_WORK_DIR}/e2e
        //             # 检测变更模块
        //             CHANGED=\\\$(gh pr diff "\\\${PR_NUM}" --repo ${REPO} --name-only 2>/dev/null || echo "")
        //             BACKEND_CHANGED=false
        //             FRONTEND_CHANGED=false
        //             if echo "\\\$CHANGED" | grep -q "^backend/"; then BACKEND_CHANGED=true; fi
        //             if echo "\\\$CHANGED" | grep -q "^frontend/"; then FRONTEND_CHANGED=true; fi
        //             echo "变更检测: backend=\\\$BACKEND_CHANGED frontend=\\\$FRONTEND_CHANGED"
        //             echo "变更文件: \\\$(echo \\"\\\$CHANGED\\" | head -10)"
        //
        //             PLAYWRIGHT_ARGS="--reporter=list --timeout=120000"
        //             PLAYWRIGHT_PATTERNS=""
        //
        //             # 后端变更：跑所有 backend smoke
        //             if [ "\\\$BACKEND_CHANGED" = "true" ]; then
        //                 PLAYWRIGHT_PATTERNS="tests/backend/"
        //             fi
        //
        //             # 前端变更：追加 frontend smoke
        //             if [ "\\\$FRONTEND_CHANGED" = "true" ]; then
        //                 if [ -n "\\\$PLAYWRIGHT_PATTERNS" ]; then
        //                     PLAYWRIGHT_PATTERNS="\\\$PLAYWRIGHT_PATTERNS tests/front/"
        //                 else
        //                     PLAYWRIGHT_PATTERNS="tests/front/"
        //                 fi
        //             fi
        //
        //             # 兜底：两端都无变更时只跑 backend smoke
        //             if [ -z "\\\$PLAYWRIGHT_PATTERNS" ]; then
        //                 echo "⚠️ 未检测到 backend/frontend 变更，降级跑 backend smoke 兜底"
        //                 PLAYWRIGHT_PATTERNS="tests/backend/"
        //             fi
        //
        //             echo "🎯 运行 Playwright: \\\${PLAYWRIGHT_PATTERNS}"
        //             BASE_URL_API=http://localhost:${CI_BACKEND_PORT} \
        //             BASE_URL_FRONT=http://localhost:${CI_FRONTEND_PORT} \
        //             npx playwright test \\\$PLAYWRIGHT_PATTERNS \\\$PLAYWRIGHT_ARGS || true
        //         """
        //     }
        // }

        // ── 阶段6：自动合并 PR ───────────────────────────────────────────
        stage('自动合并') {
            when {
                expression {
                    def pr = params.PR_NUMBER ?: env.PR_NUMBER
                    def result = currentBuild.result ?: 'SUCCESS'
                    return pr?.trim() && result != 'FAILURE' && result != 'ABORTED'
                }
            }
            steps {
                withCredentials([string(credentialsId: 'github-weiping-token', variable: 'WEIPING_TOKEN')]) {
                    script {
                        def pr = params.PR_NUMBER ?: env.PR_NUMBER
                        def buildResult = currentBuild.result ?: 'SUCCESS'
                        sh script: '''#!/bin/bash
PR_NUMBER=''' + pr + '''
BUILD_RESULT=''' + buildResult + '''
GH_TOKEN="${WEIPING_TOKEN}"
REPO="WnadeyaowuOraganization/wande-play"
CI_WORK_DIR="/home/ubuntu/projects/wande-play-ci"
JENKINS_DIR="/data/home/ubuntu/projects/.github/jenkins"
SCRIPTS_DIR="/data/home/ubuntu/projects/.github/scripts"
export GH_TOKEN REPO CI_WORK_DIR JENKINS_DIR SCRIPTS_DIR
if [ "$BUILD_RESULT" = "FAILURE" ] || [ "$BUILD_RESULT" = "ABORTED" ]; then
    echo "[MERGE SKIP] Build result=$BUILD_RESULT — skipping merge"
    exit 0
fi
CONFLICTS=$(git -C "$CI_WORK_DIR" merge-tree origin/dev HEAD 2>/dev/null | grep -c "<<<<<<" | head -1 || echo "0")
printf "[DEBUG] CONFLICTS=[%s]\n" "$CONFLICTS"
MERGED=false
if [ "$CONFLICTS" = "0" ]; then
    echo "Branch is clean vs dev — retrying merge until GitHub refreshes (up to 60s)..."
    for i in 1 2 3 4 5 6; do
        if gh pr merge "$PR_NUMBER" --repo "$REPO" --squash --delete-branch --admin; then
            echo "MERGE SUCCESS"
            MERGED=true
            break
        fi
        echo "Attempt $i failed, waiting 10s for GitHub to refresh..."
        sleep 10
    done
else
    echo "Real conflicts detected ($CONFLICTS markers), cannot auto-merge"
fi
if [ "$MERGED" = "true" ]; then
    echo "Closing Issue and releasing kimi lock..."
    BRANCH_NAME=$(gh pr view "$PR_NUMBER" --repo "$REPO" --json headRefName --jq .headRefName)
    ISSUE_NUM=$(echo "$BRANCH_NAME" | grep -oE '[0-9]+' | tail -1)
    if [ -z "$ISSUE_NUM" ]; then
        BODY_TITLE=$(gh pr view "$PR_NUMBER" --repo "$REPO" --json body,title --jq ".body + " " + .title")
        ISSUE_NUM=$(echo "$BODY_TITLE" | grep -oE '#[[:digit:]]+' | head -1 | tr -d '#')
    fi
    if [ -n "$ISSUE_NUM" ] && [ "$ISSUE_NUM" -gt 0 ] 2>/dev/null; then
        echo "Processing Issue #$ISSUE_NUM"
        gh issue close "$ISSUE_NUM" --repo "$REPO" --reason completed || true
        bash "$JENKINS_DIR/update-project-status.sh" --repo play --issue "$ISSUE_NUM" --status "Done" || true
        bash "$JENKINS_DIR/release-cc-lock.sh" "$ISSUE_NUM" || true
    fi
fi
'''
                    }
                }
            }
        }

        // ── 阶段7：并行部署（前后端独立，同时进行）─────────────────────────
        stage('并行部署') {
            when {
                expression {
                    return env.HAS_BACKEND == 'true' || env.HAS_FRONTEND == 'true'
                }
            }
            stages {
                stage('部署后端') {
                    when { expression { return env.HAS_BACKEND == 'true' } }
                    steps {
                        script {
                            def oldPid = sh(script: "pgrep -f 'ruoyi-admin' 2>/dev/null || echo ''", returnStdout: true).trim()
                            env.OLD_BACKEND_PID = oldPid
                            echo "prev PID: ${env.OLD_BACKEND_PID}"
                        }
                        sh """
                            cd ${CI_WORK_DIR}
                            # 直接从 PR 合并后代码构建（无需重新 fetch）
                            cd backend
                            mvn clean package -Pprod -Dmaven.test.skip=true -T 1 -q
                            bash /apps/wande-ai-backend/start.sh
                            # health check + PID swap verification (max 150s)
                            for i in \$(seq 1 30); do
                                NEW_PID=\$(pgrep -f 'ruoyi-admin' 2>/dev/null || echo '')
                                echo "check \$i: PID=\$NEW_PID (prev=${env.OLD_BACKEND_PID})"
                                curl -sf http://localhost:6040/ > /dev/null 2>&1 || { echo "port 6040 not responding, waiting..."; sleep 5; continue; }
                                if [ -n "\$NEW_PID" ] && [ "\$NEW_PID" != "${env.OLD_BACKEND_PID}" ]; then
                                    echo "backend deploy OK (PID: \$NEW_PID)"
                                    exit 0
                                elif [ -z "\$NEW_PID" ]; then
                                    echo "process disappeared, retrying..."
                                else
                                    echo "PID unchanged, old process may still be running..."
                                fi
                                sleep 5
                            done
                            echo "backend health check timeout, rolling back..."
                            cp /apps/wande-ai-backend/ruoyi-admin.jar.bak /apps/wande-ai-backend/ruoyi-admin.jar 2>/dev/null || true
                            bash /apps/wande-ai-backend/start.sh
                            exit 1
                        """
                    }
                }
                stage('部署前端') {
                    when { expression { return env.HAS_FRONTEND == 'true' } }
                    steps {
                        sh """
                            cd ${CI_WORK_DIR}/frontend
                            rm -rf .turbo node_modules/.cache apps/web-antd/dist
                            pnpm install --frozen-lockfile 2>/dev/null || pnpm install
                            pnpm build:antd
                            sudo chown -R ubuntu:ubuntu /apps/wande-ai-front/ 2>/dev/null || true
                            rsync -a --delete apps/web-antd/dist/ /apps/wande-ai-front/
                            sudo nginx -s reload
                            # health check
                            for i in \$(seq 1 10); do
                                curl -sf http://localhost:8080/ > /dev/null 2>&1 && echo "frontend deploy OK" && exit 0
                                sleep 3
                            done
                            exit 1
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            sh """
                PID=\$(lsof -ti :${CI_BACKEND_PORT} 2>/dev/null || true)
                [ -n "\$PID" ] && kill \$PID 2>/dev/null || true
                rm -rf ${CI_WORK_DIR}
            """
        }
        failure {
            script {
                def pr = params.PR_NUMBER ?: env.PR_NUMBER
                if (pr?.trim()) {
                    // 跳过 closed PR，避免 cycle-merge 死循环
                    sh """
                        PR_STATE=\$(gh pr view ${pr} --repo ${REPO} --json state --jq '.state')
                        if [ "\${PR_STATE}" = "closed" ]; then
                            echo "PR #${pr} is closed, skipping failure handler to prevent cycle-merge loop"
                            exit 0
                        fi
                    """
                    env.FAIL_PR_NUM = pr
                    env.FAIL_BUILD_URL = env.BUILD_URL ?: ''
                    sh "bash ${SCRIPTS_DIR}/jenkins-failure-handler.sh || true"
                }
            }
        }
    }
}
