{
  "_doc": "多源Key池配置 — Token Pool Proxy v2",
  "_usage": "复制此文件为 keys.json，填入实际API Key",

  "keys": [
    {
      "name": "zhipu_max_1",
      "type": "zhipu",
      "api_key": "YOUR_ZHIPU_API_KEY",
      "enabled": true
    },
    {
      "name": "zhipu_max_2",
      "type": "zhipu",
      "api_key": "YOUR_SECOND_ZHIPU_KEY",
      "enabled": false
    },
    {
      "name": "aiopus_pool",
      "type": "openai_compat",
      "api_url": "https://newapi.aiopus.org",
      "api_key": "sk-YOUR_AIOPUS_KEY",
      "model": "glm-5.1",
      "model_map": {
        "glm-5.1": "glm-5.1",
        "glm-5-turbo": "glm-5",
        "glm-4.5-air": "glm-5"
      },
      "_note": "中转站Key，按量计费，无5h/周限额",
      "enabled": true
    }
  ],

  "upstream": {
    "base_url": "https://open.bigmodel.cn/api/anthropic",
    "default_models": {
      "haiku": "glm-4.5-air",
      "sonnet": "glm-5-turbo",
      "opus": "glm-5.1"
    }
  },

  "fallback": {
    "enabled": true,
    "vllm_url": "http://localhost:8000/v1/chat/completions",
    "vllm_model": "/model",
    "_note": "本地Qwen3.5-122B-A10B via vLLM"
  },

  "cooldown": {
    "rate_limit_hours": 5,
    "weekly_limit_hours": 168,
    "balance_exhausted_hours": 720,
    "_note": "5h限额→5h冷却, 周限额→168h, 余额不足→720h(30天)"
  }
}
